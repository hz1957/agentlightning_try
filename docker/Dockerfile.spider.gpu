FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV VERL_SPIDER_DATA_DIR=/app/examples/spider/data
ENV PYTHONUNBUFFERED=1
ENV PATH="/opt/venv/bin:/root/.local/bin:/usr/local/bin:${PATH}"

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    git \
    libaio-dev \
    ninja-build \
    pkg-config \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
 && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir --upgrade pip uv \
 && mkdir -p /root/.local/bin \
 && ln -sf /usr/local/bin/uv /root/.local/bin/uv \
 && ln -sf /usr/bin/python3 /usr/local/bin/python

WORKDIR /app

RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --locked --no-install-project \
    --group dev \
    --group core-stable \
    --group langchain \
    --group sql \
    --group image \
    --group torch-gpu-stable

COPY . /app

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked \
    --group dev \
    --group core-stable \
    --group langchain \
    --group sql \
    --group image \
    --group torch-gpu-stable

ENTRYPOINT []
CMD ["sleep", "infinity"]
